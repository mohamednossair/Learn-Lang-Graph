# ─── LLM Provider ────────────────────────────────────────────────────────────
# "ollama" (default, local) or "bedrock" (AWS)
LLM_PROVIDER=ollama

# Ollama settings (used when LLM_PROVIDER=ollama)
OLLAMA_MODEL=qwen3:0.6b
OLLAMA_BASE_URL=http://localhost:11434
LLM_TEMPERATURE=0.0

# Bedrock settings (used when LLM_PROVIDER=bedrock)
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
AWS_REGION=us-east-1
# AWS credentials — use IAM role in production, never hardcode here
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ─── Checkpointer ────────────────────────────────────────────────────────────
# Local file checkpoints (default — no dependencies)
CHECKPOINTS_DIR=./checkpoints

# S3 checkpointer (swap in production)
# CHECKPOINTER=s3
# S3_BUCKET=my-agent-checkpoints

# ─── Optional: Solr long-term memory ─────────────────────────────────────────
# Leave unset to disable long-term memory (safe for local dev)
# SOLR_URL=http://localhost:8983/solr

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
