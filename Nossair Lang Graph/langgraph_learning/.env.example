# ============================================================
# LangGraph Enterprise Lessons — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ---- Oracle 19c (Lesson 16) --------------------------------
ORACLE_USER=langgraph
ORACLE_PASSWORD=your_oracle_password_here
ORACLE_HOST=your-oracle-host.example.com
ORACLE_PORT=1521
ORACLE_SERVICE=ORCLPDB1
USE_ORACLE=false           # set true to use OracleSaver; false = MemorySaver fallback
APP_ENV=development        # development | staging | production

# ---- JWT Auth (Lesson 17) ----------------------------------
JWT_SECRET=change-me-in-production-minimum-32-characters-long
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ---- Observability (Lesson 18) -----------------------------
USE_JSON_LOGS=false        # set true for ELK/Datadog JSON log format
SLA_P99_LATENCY_SECONDS=5.0
SLA_ERROR_RATE_THRESHOLD=0.05
# PROMETHEUS_PORT=9090     # uncomment to expose /metrics endpoint

# ---- Event-Driven / Celery (Lesson 19) --------------------
REDIS_URL=redis://localhost:6379/0
USE_CELERY=false           # set true when a Celery worker is running
WEBHOOK_SECRET=dev-secret-change-in-production

# ---- AWS Bedrock (Lesson 21) --------------------------------
# Option A: explicit credentials (local dev, CI/CD)
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
# AWS_PROFILE=default          # named profile from ~/.aws/credentials

# Model to use by default (can be overridden per-request)
# Haiku  = fastest/cheapest:  anthropic.claude-3-haiku-20240307-v1:0
# Sonnet = balanced:          anthropic.claude-3-sonnet-20240229-v1:0
# Llama  = open-weight:       meta.llama3-8b-instruct-v1:0
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Optional: Bedrock Guardrails (content filtering)
# BEDROCK_GUARDRAIL_ID=your-guardrail-id
# BEDROCK_GUARDRAIL_VERSION=DRAFT

# ---- LLM (all lessons) -------------------------------------
# Ollama runs locally — no API key required
# For LangSmith tracing (optional):
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=langgraph-enterprise
# LANGCHAIN_API_KEY=ls__your_key_here
